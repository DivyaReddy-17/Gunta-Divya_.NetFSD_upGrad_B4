@model List<Week_6_day_2_Problem1.Models.Product>
@{
    ViewData["Title"] = "PRODUCTS";
    
}
<h1>Product Details</h1>
<a href="Product/Add Product">Add Product</a>
<table border="1">
    
        <tr>
            <th>ProductId</th>
            <th>ProductName</th>
        </tr>
    
    
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.ProductId</td>
                <td>@p.ProductName</td>
            <td>
                <a asp-action="Details" asp-route-id="@p.ProductId">View</a>
                <a asp-action="Edit" asp-route-id="@p.ProductId">Edit</a>
                <a asp-action="Delete" asp-route-id="@p.ProductId">Delete</a>


            </td>
            </tr>
        }
</table>